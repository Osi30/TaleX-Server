# Copy this file to .env and fill in real values
# Usage: docker-compose --env-file .env up --build

# Redis Cloud
REDIS_PASSWORD=your_redis_password_here

# JWT (base64-encoded secret, min 32 bytes)
JWT_SECRET=your_base64_jwt_secret_here

# Google OAuth2 (from Google Cloud Console)
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_IOS=

# Gmail SMTP (App Password, not your real Gmail password)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
